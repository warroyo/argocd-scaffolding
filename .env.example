# Copy to .env (gitignored) and fill in. The Makefile sources this into every terraform
# root (infra, bootstrap, state-backend) via the shell, so normal shell syntax works:
# quotes are optional, values may contain special chars when quoted.

# vCFA access — used by infra, bootstrap, and the state-backend helper.
TF_VAR_vcfa_refresh_token=
TF_VAR_vcfa_url=https://vcfa.example.com
TF_VAR_vcfa_org=
TF_VAR_region_name=

# Load-balancer mode — MUST match what your region actually runs.
#   AVI/NSX-ALB region  → TF_VAR_avi_enabled=true  (VPC gets loadBalancerVPCEndpoint;
#                         set TF_VAR_seg_name to your Service Engine Group)
#   NSX_LB region       → TF_VAR_avi_enabled=false (VPC gets an NSX LoadBalancer CR;
#                         leave TF_VAR_seg_name commented)
# Default false. A mismatch fails apply-infra at VPC creation.
# (AKO itself is auto-installed into VKS clusters by VCF 9.1 — no AKO secret to set.)
TF_VAR_avi_enabled=false
# Service Engine Group applied to each supervisor namespace. REQUIRED when
# avi_enabled=true — uncomment and set. Leave COMMENTED for NSX_LB regions so the
# variable stays null (an empty value is not the same as unset and may be rejected).
#TF_VAR_seg_name=your-service-engine-group

# One-time state-namespace step (GETTING-STARTED Part 1). Filled into
# terraform/state-namespace/state-namespace.yaml via envsubst (regionName reuses
# TF_VAR_region_name above). NOT read by any terraform root — sourced only for
# that one manual step. No safe defaults; set to match your install.
STATE_NS_VPC=              # e.g. default-us-east-a
STATE_NS_ZONE=             # e.g. z-wld-a
STATE_NS_STORAGE_POLICY=   # e.g. vsan-default-storage-policy

# Bootstrap (ArgoCD) — used by apply-bootstrap.
TF_VAR_argo_password=
# repo_url: leave EMPTY to use argocd/repo-config.yaml (the single source of
# truth, also injected into the ApplicationSets). Set only to deliberately
# point the root app at a different repo.
TF_VAR_repo_url=
