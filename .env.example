# Copy to .env (gitignored) and fill in. The Makefile auto-loads and exports these to
# every terraform root (infra, bootstrap, state-backend). KEY=value — no quotes, no spaces
# around =, and avoid '#' inside values (it starts a comment).

# vCFA access — used by infra, bootstrap, and the state-backend helper.
TF_VAR_vcfa_refresh_token=
TF_VAR_vcfa_url=https://vcfa.example.com
TF_VAR_vcfa_org=
TF_VAR_region_name=

# Bootstrap (ArgoCD + AKO) — used by apply-bootstrap.
TF_VAR_argo_password=
TF_VAR_repo_url=https://github.com/your-org/argocd-scaffolding
TF_VAR_ako_username=
TF_VAR_ako_password=
TF_VAR_ako_ca_data=
