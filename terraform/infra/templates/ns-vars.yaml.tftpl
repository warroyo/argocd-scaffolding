#
# Per-namespace handoff of the vcfa-SUFFIXED supervisor namespace name — the one
# thing a cluster author can't know. Consumed apps-side by cluster-var-injector
# to build the secret-store ClusterSecretStore mount/role. See CLAUDE.md
# "Source of truth" and docs/DECISIONS.md (namespace handles).

apiVersion: v1
kind: ConfigMap
metadata:
  name: ns-vars
  annotations:
    config.kubernetes.io/local-config: "true"
data:
  # vcfa-suffixed name (e.g. dev-1-abcde). Deploy target + secret-store role.
  supervisor_namespace: "${supervisor_namespace}"
  # Secret Store k8s-auth mount path is always kubernetes-<supervisor_ns>.
  secret_store_auth_mount: "kubernetes-${supervisor_namespace}"
